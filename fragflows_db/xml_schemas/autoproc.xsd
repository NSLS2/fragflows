                                                                                                <xs:sequence>
                                                                                                        <xs:element name="cell_a" type="xs:decimal" />
                                                                                                        <xs:element name="cell_b" type="xs:decimal" />
                                                                                                        <xs:element name="cell_c" type="xs:decimal" />
