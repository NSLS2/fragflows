                                                                                                        <xs:element name="cell_beta" type="xs:decimal" />
                                                                                                        <xs:element name="cell_gamma" type="xs:decimal" />
                                                                                                        <xs:element name="startImageNumber" type="xs:unsignedByte" />
                                                                                                        <xs:element name="endImageNumber" type="xs:unsignedShort" />
                                                                                                        <xs:element name="refinedDetectorDistance" type="xs:decimal" />
                                                                                                        <xs:element name="refinedXBeam" type="xs:decimal" />
                                                                                                        <xs:element name="refinedYBeam" type="xs:decimal" />
                                                                                                        <xs:element name="rotationAxisX" type="xs:decimal" />
                                                                                                        <xs:element name="rotationAxisY" type="xs:decimal" />
                                                                                                        <xs:element name="rotationAxisZ" type="xs:decimal" />
                                                                                                        <xs:element name="beamVectorX" type="xs:decimal" />
                                                                                                        <xs:element name="beamVectorY" type="xs:decimal" />
                                                                                                        <xs:element name="beamVectorZ" type="xs:decimal" />
                                                                                                </xs:sequence>
                                                                                        </xs:complexType>
                                                                                </xs:element>
                                                                        </xs:sequence>
                                                                </xs:complexType>
                                                        </xs:element>
                                                </xs:sequence>
                                        </xs:complexType>
                                </xs:element>
                        </xs:sequence>
                </xs:complexType>
        </xs:element>
</xs:schema>