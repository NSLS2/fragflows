                                                                        <xs:sequence>
                                                                                <xs:element name="processingCommandLine" type="xs:string" />
                                                                                <xs:element name="processingPrograms" type="xs:string" />
                                                                                <xs:element name="processingStatus" type="xs:unsignedByte" />
                                                                                <xs:element name="processingMessage" />
                                                                                <xs:element name="processingStartTime" type="xs:string" />
                                                                                <xs:element name="processingEndTime" type="xs:string" />
                                                                                <xs:element name="processingEnvironment" type="xs:string" />
                                                                        </xs:sequence>
                                                                </xs:complexType>
                                                        </xs:element>
                                                        <xs:element maxOccurs="unbounded" name="AutoProcProgramAttachment">
                                                                <xs:complexType>
                                                                        <xs:sequence>
                                                                                <xs:element name="fileType" type="xs:string" />
                                                                                <xs:element name="fileName" type="xs:string" />
                                                                                <xs:element name="filePath" type="xs:string" />
                                                                        </xs:sequence>
                                                                </xs:complexType>
                                                        </xs:element>
                                                </xs:sequence>
                                        </xs:complexType>
                                </xs:element>
                                <xs:element name="AutoProc">
                                        <xs:complexType>
                                                <xs:sequence>
                                                        <xs:element name="spaceGroup" type="xs:string" />
                                                        <xs:element name="wavelength" type="xs:decimal" />
                                                        <xs:element name="refinedCell_a" type="xs:decimal" />
                                                        <xs:element name="refinedCell_b" type="xs:decimal" />
                                                        <xs:element name="refinedCell_c" type="xs:decimal" />
                                                        <xs:element name="refinedCell_alpha" type="xs:decimal" />
                                                        <xs:element name="refinedCell_beta" type="xs:decimal" />
                                                        <xs:element name="refinedCell_gamma" type="xs:decimal" />
                                                </xs:sequence>
                                        </xs:complexType>
                                </xs:element>
                                <xs:element name="AutoProcScalingContainer">
                                        <xs:complexType>
                                                <xs:sequence>
                                                        <xs:element name="AutoProcScaling">
                                                                <xs:complexType>
                                                                        <xs:sequence>
                                                                                <xs:element name="recordTimeStamp" type="xs:string" />
                                                                        </xs:sequence>
                                                                </xs:complexType>
                                                        </xs:element>
                                                        <xs:element maxOccurs="unbounded" name="AutoProcScalingStatistics">
                                                                <xs:complexType>
                                                                        <xs:sequence>
                                                                                <xs:element name="scalingStatisticsType" type="xs:string" />
                                                                                <xs:element name="resolutionLimitLow" type="xs:decimal" />
                                                                                <xs:element name="resolutionLimitHigh" type="xs:decimal" />
