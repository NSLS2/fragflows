                                                                                <xs:element name="anomalousCompleteness" type="xs:decimal" />
                                                                                <xs:element name="anomalousMultiplicity" type="xs:decimal" />
                                                                                <xs:element name="ccAnomalous" type="xs:decimal" />
                                                                                <xs:element name="DanoOverSigDano" type="xs:decimal" />
                                                                        </xs:sequence>
                                                                </xs:complexType>
                                                        </xs:element>
                                                        <xs:element name="AutoProcIntegrationContainer">
                                                                <xs:complexType>
                                                                        <xs:sequence>
                                                                                <xs:element name="Image">
                                                                                        <xs:complexType>
                                                                                                <xs:sequence>
                                                                                                        <xs:element name="fileName" type="xs:string" />
                                                                                                        <xs:element name="fileLocation" type="xs:string" />
                                                                                                </xs:sequence>
                                                                                        </xs:complexType>
                                                                                </xs:element>
                                                                                <xs:element name="AutoProcIntegration">
